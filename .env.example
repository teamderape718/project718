# Server
PORT=3000
NODE_ENV=development

# Database (dedupe + price history) — avec docker-compose.yml du projet :
# DATABASE_URL=postgresql://qcfa:qcfa@localhost:5432/qcfa

# AI (optional — pipeline skips if unset)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant

# Pipeline: minimum Groq score 0–100 to keep lead (when GROQ_API_KEY set)
# GROQ_MIN_SCORE=40

# Telnyx SMS
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=+1xxxxxxxxxx
# Optional: required by some Telnyx messaging setups
# TELNYX_MESSAGING_PROFILE_ID=

# Your mobile for deal alerts
NOTIFY_SMS_TO=+1xxxxxxxxxx

# Scraper
# Kijiji — Québec ou Montréal (exemple Montréal) :
# KIJIJI_QUEBEC_AUTOS_URL=https://www.kijiji.ca/b-autos-camions/ville-de-montreal/c174l1700281
KIJIJI_QUEBEC_AUTOS_URL=https://www.kijiji.ca/b-autos-camions/quebec/c174l9001
# Playwright: set to 1 to see the browser
HEADLESS=1

# Bot Telegram (npm run bot) — SMS vendeur via Telnyx si numéro sur la fiche
TELEGRAM_BOT_TOKEN=
# Optionnel : restreindre à tes chats (IDs séparés par des virgules). Laisse vide pour tests.
# TELEGRAM_ALLOWED_CHAT_IDS=123456789
TELEGRAM_SCAN_PAGES=2
TELEGRAM_DEALS_MAX=5
TELEGRAM_MIN_MARGIN_PCT=10

# Site + admin (JWT) — HTTPS pour les liens Telegram
JWT_SECRET=changez-moi-minimum-16-caracteres
# Créer le 1er compte admin (une fois) : npm run seed:admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changez-moi-8chars
PUBLIC_SITE_URL=https://votre-domaine.com

# Déploiement auto (deploy/deploy-auto.sh) — email pour Let's Encrypt
# DEPLOY_SSL_EMAIL=toi@example.com
